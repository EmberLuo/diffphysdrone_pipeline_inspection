<launch>
  <arg name="drone_id" default="0"/>
  <arg name="odom_topic" default="/Odometry"/>
  <arg name="cloud_topic" default="/cloud_registered"/>
  <arg name="map_size_x" default="70.0"/>
  <arg name="map_size_y" default="70.0"/>
  <arg name="map_size_z" default="10.0"/>
  <arg name="max_vel" default="1.0"/>
  <arg name="max_acc" default="2.0"/>
  <arg name="planning_horizon" default="6.0"/>
  <arg name="flight_type" default="1"/>
  <arg name="enable_traj_server" default="false"/>

  <include file="$(find ego_planner)/launch/advanced_param_exp.xml">
    <arg name="drone_id" value="$(arg drone_id)"/>
    <arg name="map_size_x_" value="$(arg map_size_x)"/>
    <arg name="map_size_y_" value="$(arg map_size_y)"/>
    <arg name="map_size_z_" value="$(arg map_size_z)"/>
    <arg name="odometry_topic" value="$(arg odom_topic)"/>
    <arg name="obj_num_set" value="0"/>
    <arg name="camera_pose_topic" value="nouse_camera_pose"/>
    <arg name="depth_topic" value="nouse_depth"/>
    <arg name="cloud_topic" value="$(arg cloud_topic)"/>
    <arg name="cx" value="321.04638671875"/>
    <arg name="cy" value="243.44969177246094"/>
    <arg name="fx" value="387.229248046875"/>
    <arg name="fy" value="387.229248046875"/>
    <arg name="max_vel" value="$(arg max_vel)"/>
    <arg name="max_acc" value="$(arg max_acc)"/>
    <arg name="planning_horizon" value="$(arg planning_horizon)"/>
    <arg name="use_distinctive_trajs" value="false"/>
    <arg name="flight_type" value="$(arg flight_type)"/>
    <arg name="point_num" value="1"/>
    <arg name="point0_x" value="10.0"/>
    <arg name="point0_y" value="0.0"/>
    <arg name="point0_z" value="1.5"/>
    <arg name="point1_x" value="0.0"/>
    <arg name="point1_y" value="0.0"/>
    <arg name="point1_z" value="1.5"/>
    <arg name="point2_x" value="0.0"/>
    <arg name="point2_y" value="0.0"/>
    <arg name="point2_z" value="1.5"/>
    <arg name="point3_x" value="0.0"/>
    <arg name="point3_y" value="0.0"/>
    <arg name="point3_z" value="1.5"/>
    <arg name="point4_x" value="0.0"/>
    <arg name="point4_y" value="0.0"/>
    <arg name="point4_z" value="1.5"/>
  </include>

  <node if="$(arg enable_traj_server)" pkg="ego_planner" name="drone_$(arg drone_id)_traj_server" type="traj_server" output="screen">
    <remap from="position_cmd" to="/planning/pos_cmd"/>
    <remap from="~planning/bspline" to="/drone_$(arg drone_id)_planning/bspline"/>
    <param name="traj_server/time_forward" value="1.0" type="double"/>
  </node>
</launch>
