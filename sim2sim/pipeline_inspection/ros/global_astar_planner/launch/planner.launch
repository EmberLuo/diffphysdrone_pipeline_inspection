<launch>
  <arg name="repo_root" default="$(env REPO_ROOT)"/>
  <arg name="map_path" default="$(arg repo_root)/assets/maps/powerplant_local.pcd"/>
  <arg name="odom_topic" default="/Odometry"/>
  <arg name="goal_topic" default="/move_base_simple/goal"/>
  <arg name="path_topic" default="/global_path"/>
  <arg name="resolution" default="0.25"/>
  <arg name="search_step" default="0.5"/>
  <arg name="default_goal_z" default="1.2"/>

  <node pkg="global_astar_planner" type="global_astar_planner_node" name="global_astar_planner" output="screen">
    <param name="map_path" value="$(arg map_path)"/>
    <param name="odom_topic" value="$(arg odom_topic)"/>
    <param name="goal_topic" value="$(arg goal_topic)"/>
    <param name="path_topic" value="$(arg path_topic)"/>
    <param name="resolution" value="$(arg resolution)" type="double"/>
    <param name="search_step" value="$(arg search_step)" type="double"/>
    <param name="default_goal_z" value="$(arg default_goal_z)" type="double"/>
  </node>
</launch>
